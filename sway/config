exec_always export XDG_CURRENT_DESKTOP=sway

# Keboard layout and rebinding
input type:keyboard {
   xkb_layout "eu"
   xkb_options caps:escape
}

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $menu wofi --show drun

### Output configuration
output * bg "/home/user/Pictures/wallpaper.png" fill

font pango:JetbrainsMono Nerd Font 10

gaps outer 10
gaps inner 8
default_border pixel
title_align center
for_window [all] title_format "%title"
for_window [title="Volume Control"] floating enable 
for_window [title="Volume Control"] resize set width 40 ppt height 35 ppt


focus_follows_mouse no


#SwayFX Options
corner_radius 8
smart_corner_radius enable
shadows enable
shadow_blur_radius 20

blur enable
blur_passes 2
blur_radius 4

default_dim_inactive 0.15


set $accent #333333

# class                 border  backgr. text    indicator child_border
client.focused          $accent $accent #e8e8e8 $accent   $accent
client.focused_inactive #222222 #141414 #888888 #222222   #222222
client.unfocused        $accent #141414 #555555 #1a1a1a   #1a1a1a
client.urgent           #ff5f57 #141414 #ff5f57 #ff5f57   #ff5f57

layer_effects "waybar" {
    blur enable
    shadows enable
}

layer_effects "wofi" {
    blur enable
    shadows enable
    corner_radius 8

}


### Input configuration
focus_follows_mouse no

# Keboard layout and rebinding
input type:keyboard {
   xkb_layout "eu"
   xkb_options caps:escape
}

# Only for Laptop
# input type:touchpad {
#    dwt enabled
#    tap enabled
#    natural_scroll enabled
#    middle_emulation enabled
# }

### Key bindings
	bindsym $mod+Shift+x    exec swaylock -c 000000 -i "/home/user/Pictures/catppuccin/tree.jpg"
    bindsym $mod+Return     exec $term
	bindsym $mod+Shift+Return exec $term --class Terminal
    bindsym $mod+n exec $term --class Notes -e nvim ~/notes 
    bindsym $mod+Shift+q    kill
    bindsym $mod+d          exec $menu
    bindsym $mod+Shift+r    reload
    bindsym $mod+Shift+e    exec swaynag -t warning -m 'Exit sway?' \
    -B 'Yes, exit sway' 'swaymsg exit'
    floating_modifier $mod normal

    ### Focus movement
    bindsym $mod+$left  focus left
    bindsym $mod+$down  focus down
    bindsym $mod+$up    focus up
    bindsym $mod+$right focus right

    ### Window movement
    bindsym $mod+Shift+$left    move left
    bindsym $mod+Shift+$down    move down
    bindsym $mod+Shift+$up      move up
    bindsym $mod+Shift+$right   move right

    # Workspaces
    bindsym $mod+7 workspace number 1
    bindsym $mod+8 workspace number 2
    bindsym $mod+9 workspace number 3
    bindsym $mod+0 workspace number 4

    bindsym --whole-window $mod+button8 workspace number 1
    bindsym --whole-window $mod+button9 workspace number 2

    bindsym $mod+Shift+7 move container to workspace number 1
    bindsym $mod+Shift+8 move container to workspace number 2
    bindsym $mod+Shift+9 move container to workspace number 3
    bindsym $mod+Shift+0 move container to workspace number 4

    ### Layout
    bindsym $mod+b splith
    bindsym $mod+v splitv
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split
    bindsym $mod+f fullscreen
    bindsym $mod+Shift+space floating toggle
    bindsym $mod+space focus mode_toggle
    bindsym $mod+a focus parent

	# Set coding size manually
	bindsym $mod+F11 resize set width 60 ppt height 100 ppt
	bindsym $mod+F12 move position center

	# screenshot
    bindsym $mod+Print exec grim -g "$(slurp)" - | wl-copy
    bindsym $mod+Shift+Print exec sh -c 'grim -g "$(slurp)" ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png'
	# Create centered floating terminal instance 
	for_window [app_id="Terminal"] floating enable
	for_window [app_id="Terminal"] resize set width 60 ppt height 100 ppt
	for_window [app_id="Terminal"] move position center

	for_window [app_id="Notes"] floating enable
	for_window [app_id="Notes"] resize set width 50 ppt height 70 ppt
	for_window [app_id="Notes"] move position center


    # Scratchpad
    bindsym $mod+Shift+minus move scratchpad
    bindsym $mod+minus scratchpad show

### Resize mode
mode "󰘖" {
    bindsym $left  resize shrink width  10px
    bindsym $down  resize grow   height 10px
    bindsym $up    resize shrink height 10px
    bindsym $right resize grow   width  10px

    bindsym Left  resize shrink width  10px
    bindsym Down  resize grow   height 10px
    bindsym Up    resize shrink height 10px
    bindsym Right resize grow   width  10px

    bindsym Return  mode "default"
    bindsym Escape  mode "default"
}
bindsym $mod+r mode "󰘖"

# Utilities:
    # Special keys to adjust volume via PulseAudio
    bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
    bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
    bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
    bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
    # Special keys to adjust brightness via brightnessctl
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+



# Bar
bar {
	swaybar_command waybar
}
